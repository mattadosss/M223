{
  "name": "Quarkus Dev",
  "dockerComposeFile": "docker-compose.yml",
  "service": "quarkus",
  "workspaceFolder": "/workspace",
  "runServices": ["db", "quarkus"],
  "shutdownAction": "stopCompose",
  "forwardPorts": [8080],
  "postCreateCommand": "mvn -q -DskipTests clean install",
  "remoteUser": "root",

  "customizations": {
    "vscode": {
      "extensions": [
        "openai.chatgpt"
      ]
    }
  },

  "mounts": [
    "source=${localEnv:HOME}/.codex,target=/root/.codex,type=bind,consistency=cached"
  ]
}