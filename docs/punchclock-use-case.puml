@startuml
title Punchclock – UML-Anwendungsfalldiagramm

left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor "API-Benutzer" as User

rectangle "Punchclock-System" {
  usecase "Mitarbeiter erfassen" as UC_CreateEmployee
  usecase "Alle Mitarbeiter\nanzeigen" as UC_ListEmployees
  usecase "Mitarbeiterdetails\nanzeigen" as UC_GetEmployee

  usecase "Zeiteintrag erfassen" as UC_CreateEntry
  usecase "Alle Zeiteinträge\nanzeigen" as UC_ListEntries
  usecase "Zeiteintragsdetails\nanzeigen" as UC_GetEntry

  usecase "Zugehörigen Mitarbeiter\nprüfen" as UC_CheckEmployee
}

User --> UC_CreateEmployee
User --> UC_ListEmployees
User --> UC_GetEmployee
User --> UC_CreateEntry
User --> UC_ListEntries
User --> UC_GetEntry

UC_CreateEntry ..> UC_CheckEmployee : <<include>>

note right of UC_CreateEntry
  Ein Eintrag enthält Check-in,
  optional Check-out und die
  Mitarbeiterzuordnung.
end note

@enduml
