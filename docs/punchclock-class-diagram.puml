@startuml
title Punchclock – UML-Klassendiagramm

skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
hide empty members

package controller {
  class EmployeeController <<REST Controller>> {
    - employeeService: EmployeeService
    + getAllEmployees(): List<Employee>
    + getEmployee(id: Long): Response
    + createEmployee(employee: Employee): Response
  }

  class EntryController <<REST Controller>> {
    - entryService: EntryService
    + getAllEntries(): List<Entry>
    + getEntry(id: Long): Response
    + createEntry(entry: Entry): Response
  }
}

package service {
  class EmployeeService <<Service>> {
    - employeeRepository: EmployeeRepository
    + findAll(): List<Employee>
    + findById(id: Long): Employee
    + createEmployee(employee: Employee): Employee
  }

  class EntryService <<Service>> {
    - entryRepository: EntryRepository
    - employeeRepository: EmployeeRepository
    + findAll(): List<Entry>
    + findById(id: Long): Entry
    + createEntry(entry: Entry): Entry
  }
}

package repository {
  interface "PanacheRepository<Employee>" as PanacheEmployee
  interface "PanacheRepository<Entry>" as PanacheEntry

  class EmployeeRepository <<Repository>>
  class EntryRepository <<Repository>>

  PanacheEmployee <|.. EmployeeRepository
  PanacheEntry <|.. EntryRepository
}

package model {
  class Employee <<Entity>> {
    - id: Long
    - firstName: String
    - lastName: String
    - email: String
    - entries: List<Entry>
    + Employee()
    + Employee(firstName: String, lastName: String, email: String)
  }

  class Entry <<Entity>> {
    - id: Long
    - checkIn: LocalDateTime
    - checkOut: LocalDateTime
    - employee: Employee
    + Entry()
    + Entry(checkIn: LocalDateTime, employee: Employee)
  }
}

EmployeeController --> EmployeeService
EntryController --> EntryService
EmployeeService --> EmployeeRepository
EntryService --> EntryRepository
EntryService --> EmployeeRepository : prüft Zuordnung

Employee "1" <-- "0..*" Entry : employee / entries

@enduml
